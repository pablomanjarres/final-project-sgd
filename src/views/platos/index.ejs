<%- include('../partials/head') %>
  <div class="page-header">
    <h1>Platos</h1>
    <a class="btn primary" href="/platos/new">+ Nuevo plato</a>
  </div>

  <% if (platos.length === 0) { %>
    <p class="empty">Aún no hay platos registrados.</p>
  <% } else { %>
    <table>
      <thead>
        <tr>
          <th>Código</th>
          <th>Nombre</th>
          <th>Categoría</th>
          <th>Precio base</th>
          <th>Tiempo prep. (min)</th>
          <th>Acciones</th>
        </tr>
      </thead>
      <tbody>
        <% platos.forEach(p => { %>
          <tr>
            <td><%= p.codigo_plato %></td>
            <td>
              <strong><%= p.nombre %></strong>
              <% if (p.descripcion) { %><br/><small><%= p.descripcion %></small><% } %>
            </td>
            <td><%= p.categoria %></td>
            <td>$<%= Number(p.precio_base).toLocaleString('es-CO') %></td>
            <td><%= p.tiempo_prep %></td>
            <td class="actions">
              <a href="/platos/<%= p.codigo_plato %>/edit">Editar</a>
              <form action="/platos/<%= p.codigo_plato %>?_method=DELETE" method="POST" onsubmit="return confirm('¿Eliminar el plato <%= p.nombre %>?');">
                <button type="submit" class="btn danger">Eliminar</button>
              </form>
            </td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  <% } %>
<%- include('../partials/foot') %>

<%- include('../partials/head') %>
  <div class="page-header">
    <h1>Historial de salario</h1>
    <a class="btn" href="/empleados">← Volver</a>
  </div>

  <p class="lead">
    <strong><%= empleado.nombre %> <%= empleado.apellidos %></strong>
    — <%= empleado.cargo %> en <%= empleado.restaurante_nombre %>
  </p>

  <% if (historial.length === 0) { %>
    <p class="empty">No hay registros en el historial.</p>
  <% } else { %>
    <table>
      <thead>
        <tr>
          <th>#</th>
          <th>Evento</th>
          <th>Salario anterior</th>
          <th>Salario nuevo</th>
          <th>Fecha</th>
        </tr>
      </thead>
      <tbody>
        <% historial.forEach(h => { %>
          <tr>
            <td><%= h.id_historial %></td>
            <td><span class="badge <%= h.tipo_evento.toLowerCase() %>"><%= h.tipo_evento %></span></td>
            <td><%= h.salario_anterior === null ? '—' : '$' + Number(h.salario_anterior).toLocaleString('es-CO') %></td>
            <td>$<%= Number(h.salario_nuevo).toLocaleString('es-CO') %></td>
            <td><%= h.fecha_evento %></td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  <% } %>
<%- include('../partials/foot') %>
